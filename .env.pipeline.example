# .env.pipeline.example — copy to .env.pipeline (git-ignored) and fill in.
# Single source of truth for the ONE shared CometChat app across all 10 runs (§6.3).
# NEVER commit the filled-in .env.pipeline — only this .example is committed (secret-scan gate §4.6).

# ---- Shared CometChat app (from provision-app / dashboard) ----
COMETCHAT_APP_ID=
COMETCHAT_REGION=
COMETCHAT_AUTH_KEY=
COMETCHAT_REST_API_KEY=

# ---- Automation / management keys (provision-app, Phase 2.5) ----
COMETCHAT_MANAGEMENT_KEY=

# ---- Push (shared across runs) ----
COMETCHAT_FCM_SERVER_KEY=
COMETCHAT_APNS_KEY_ID=
COMETCHAT_APNS_TEAM_ID=
COMETCHAT_WEBHOOK_SECRET=
COMETCHAT_WEBHOOK_URL=

# ---- AI agent / misc ----
COMETCHAT_AI_AGENT_UID=

# ---- Per-repo namespace prefix (§6.1) — set per use case at boot, not here ----
# UC_SLUG=mkt   # marketplace | com | del | dat | fin | cre | fld | rea | rid | evt
