.env.pipeline
.env
**/.env
pipeline-state/*.json
cometchat-app-config.json
.DS_Store
.claude/settings.local.json

# --- pipeline repo: exclude generated apps, other repos, upstream skills clone ---
runs/
repos/
cometchat-skills/
node_modules/
.venv/
venv/
__pycache__/
*.pyc
.claude/
workflow/node_modules/

# Visual-baseline goldens (established per-machine on first run; not canonical test artifacts)
pipeline-state/baselines/

# resilience layer — per-run state is runtime, not source (keep only curated global policy)
pipeline-state/*/journal.jsonl
pipeline-state/*/heartbeat.json
pipeline-state/*/HALT.json
pipeline-state/*/PROGRESS.md
pipeline-state/*/COMMANDS.jsonl
pipeline-state/*/applied_commands.jsonl
pipeline-state/*/DIRECTIVES.md
pipeline-state/*/LEARNINGS.md
!pipeline-state/global/POLICY.md
!pipeline-state/global/LEARNINGS.md
